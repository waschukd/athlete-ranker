# Copy this file to .env.local and fill in real values.
# .env.local is gitignored so your real secrets stay out of version control.

# ── Required ─────────────────────────────────────────────────────────

# Neon Postgres connection string (pooled). From console.neon.tech →
# project → Connection Details → Pooled connection.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&channel_binding=require

# 32-byte random string used to sign session JWTs.
# Generate with: [Convert]::ToBase64String((1..48 | %{ Get-Random -Maximum 256 }))
AUTH_SECRET=replace-with-random-base64-from-the-command-above

# Public URL where the site is reachable. http://localhost:3000 for local dev.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Email (Resend) ───────────────────────────────────────────────────

RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=noreply@yourdomain.example

# ── Payments (Stripe) ────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Default report price in cents (US).
REPORT_PRICE_CENTS=1999
# Optional throttle on /api/payments/create-checkout.
REPORT_CHECKOUT_MAX_PER_HOUR=10
# Optional TTL on /api/report/[token] share links (days).
REPORT_TOKEN_TTL_DAYS=90

# ── AI scouting reports (Anthropic) ──────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Cron auth ────────────────────────────────────────────────────────

# Bearer used by /api/cron. Generate the same way as AUTH_SECRET.
CRON_SECRET=replace-with-random-base64

# ── Error monitoring (Sentry) — optional ─────────────────────────────

# DSN for browser-side errors (NEXT_PUBLIC_ prefix exposes it to the
# bundle, which is fine — DSNs are public-facing identifiers).
NEXT_PUBLIC_SENTRY_DSN=https://PUBLIC_KEY@oORG.ingest.sentry.io/PROJECT_ID
# DSN for server / edge errors (same value as above is fine).
SENTRY_DSN=https://PUBLIC_KEY@oORG.ingest.sentry.io/PROJECT_ID
# Source-map upload (Vercel-side, not local). Leave blank for local.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
